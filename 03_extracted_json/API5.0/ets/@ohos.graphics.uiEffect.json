    {
      "类型": "method",
      "名称": "waterRipple",
      "返回值": "Filter",
      "所属模块": "未知模块",
      "功能描述": "Set waterRipple effect of the Component. 0 for mobile to desktop(Receive), 1 for mobile to desktop(Send), 2 for mobile to mobile.",
      "注释信息": [
        "@param { number } progress - Indicates the ripple progress. The value 1 indicates that ripples are displayed on all screens.",
        "@param { number } waveCount - The number of waves when the water ripples. The maximum count of waves is 3, the minimum value is 1,  default is 2.",
        "@param { number } x - Represents the X-axis position of center point  where the water ripple first appears on the screen.",
        "@param { number } y - Represents the Y-axis position of center point  where the water ripple first appears on the screen.",
        "@param { WaterRippleMode } rippleMode - Set the mode of water ripple,",
        "@returns { Filter } - Returns  water ripple Filter.",
        "@throws { BusinessError } 202 - Permission verification failed. A non-system application calls a system API.",
        "@syscap SystemCapability.Graphics.Drawing",
        "@systemapi",
        "@since 12"
      ],
      "层级": 2,
      "上级": "Filter",
      "since_version": "12",
      "system_capability": "SystemCapability.Graphics.Drawing",
      "parameters": [
        {
          "名称": "progress",
          "类型": "number",
          "必填": true,
          "说明": "Indicates the ripple progress. The value 1 indicates that ripples are displayed on all screens."
        },
        {
          "名称": "waveCount",
          "类型": "number",
          "必填": true,
          "说明": "The number of waves when the water ripples. The maximum count of waves is 3, the minimum value is 1,  default is 2."
        },
        {
          "名称": "x",
          "类型": "number",
          "必填": true,
          "说明": "Represents the X-axis position of center point  where the water ripple first appears on the screen."
        },
        {
          "名称": "y",
          "类型": "number",
          "必填": true,
          "说明": "Represents the Y-axis position of center point  where the water ripple first appears on the screen."
        },
        {
          "名称": "rippleMode",
          "类型": "WaterRippleMode",
          "必填": true,
          "说明": "Set the mode of water ripple,"
        }
      ],
      "return_description": "- Returns  water ripple Filter.",
      "error_codes": [
        {
          "code": "202",
          "description": "Permission verification failed. A non-system application calls a system API."
        }
      ],
      "版本": "API5.0"
    },
    {
      "类型": "method",
      "名称": "flyInFlyOutEffect",
      "返回值": "Filter",
      "所属模块": "未知模块",
      "功能描述": "Set the fly in or fly out effect of the component. If the value is 0, the component keep same, else the value is 1, component are fully fly out or fly in.",
      "注释信息": [
        "@param { number } degree - set the degree of fly in or fly out effect, value range [0, 1].",
        "@param { FlyMode } flyMode - set the location of stretching when fly in or out",
        "@returns { Filter } - Returns  fly in fly out Filter.",
        "@throws { BusinessError } 202 - Permission verification failed. A non-system application calls a system API.",
        "@syscap SystemCapability.Graphics.Drawing",
        "@systemapi",
        "@since 12"
      ],
      "层级": 2,
      "上级": "Filter",
      "since_version": "12",
