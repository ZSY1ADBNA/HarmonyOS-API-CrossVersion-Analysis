    {
      "类型": "method",
      "名称": "download",
      "返回值": "void",
      "所属模块": "未知模块",
      "功能描述": "Downloads resources at the specified URL. Resources will be stored in memory cache or files cache. The maximum size of the specified URL is 8192 bytes. The maximum size of a single resource after decompression is 20,971,520 bytes(20 MB). If the decompressed size of the downloaded resource exceeds the limit, it will not be recorded in the cache. <br>2. Incorrect parameter type. 3. Parameter verification failed.",
      "注释信息": [
        "@permission ohos.permission.INTERNET",
        "@param { string } url - URL of the cache download target.",
        "@param { CacheDownloadOptions } options - Options of the cache download task.",
        "@throws { BusinessError } 201 - permission denied.",
        "@throws { BusinessError } 401 - parameter error. Possible causes: 1. Missing mandatory parameters.",
        "@syscap SystemCapability.Request.FileTransferAgent",
        "@since 18"
      ],
      "层级": 1,
      "上级": "cacheDownload",
      "since_version": "18",
      "system_capability": "SystemCapability.Request.FileTransferAgent",
      "parameters": [
        {
          "名称": "url",
          "类型": "string",
          "必填": true,
          "说明": "URL of the cache download target."
        },
        {
          "名称": "options",
          "类型": "CacheDownloadOptions",
          "必填": true,
          "说明": "Options of the cache download task."
        }
      ],
      "return_description": "",
      "error_codes": [
        {
          "code": "201",
          "description": "permission denied."
        },
        {
          "code": "401",
          "description": "parameter error. Possible causes: 1. Missing mandatory parameters."
        }
      ],
      "版本": "API6.0"
    },
