    {
      "类型": "method",
      "名称": "getDownloadInfo",
      "返回值": "DownloadInfo | undefined",
      "所属模块": "未知模块",
      "功能描述": "Gets download information of cache downloads based on URL. These information are stored in memory and cleared when the application exits. The maximum size of the specified URL is 8192 bytes. If the specified URL can be found in the download information list, return { @link DownloadInfo } of the most recent download. If the specified URL can not be found in the download information list, return `undefined`.",
      "注释信息": [
        "@permission ohos.permission.GET_NETWORK_INFO",
        "@param { string } url - URL to be queried.",
        "@returns { DownloadInfo | undefined } the information of the specified cache download or none.",
        "@throws { BusinessError } 201 - permission denied.",
        "@syscap SystemCapability.Request.FileTransferAgent",
        "@since 20",
        "@arkts 1.1&1.2"
      ],
      "层级": 1,
      "上级": "cacheDownload",
