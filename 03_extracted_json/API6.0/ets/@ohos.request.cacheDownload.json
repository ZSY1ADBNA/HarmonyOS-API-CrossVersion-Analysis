    {
      "类型": "method",
      "名称": "setDownloadInfoListSize",
      "返回值": "void",
      "所属模块": "未知模块",
      "功能描述": "Sets the maximum size of the download information list. The download information list is used to store download infarmation. URLs and download information correspond one to one. Each download will generate a download information. Under the same URL, only the latest download information will be saved. The default value of the specified size is 0. It means no download information can be stored. The maximum value of the specified size is 8192.",
      "注释信息": [
        "@param { number } size - the size of the download information list.",
