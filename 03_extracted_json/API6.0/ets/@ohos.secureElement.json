          "名称": "type",
          "类型": "'serviceState'",
          "必填": true,
          "说明": "nfc serviceState"
        },
        {
          "名称": "callback",
          "类型": "Callback<ServiceState>",
          "必填": true,
          "说明": "The callback to return the service."
        }
      ],
      "return_description": "The new SEService instance.",
      "error_codes": [
