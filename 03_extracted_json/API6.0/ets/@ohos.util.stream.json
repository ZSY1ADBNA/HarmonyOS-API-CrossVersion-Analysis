    {
      "类型": "method",
      "名称": "write",
      "返回值": "boolean",
      "所属模块": "未知模块",
      "功能描述": "writes a chunk to Writable and invokes callback when the chunk is flushed. The return value indicates whether the internal buffer of the Writable reaches the hightWaterMark. If true is returned, the buffer does not reach the hightWaterMark. If false is returned, the buffer has been reached. The write function should be called after the drain event is triggered. If the write function is called continuously, the chunk is still added to the buffer until the memory overflows 1.Mandatory parameters are left unspecified; 2.Incorrect parameter types; 3.Parameter verification failed.",
      "注释信息": [
        "@param { string | Uint8Array } [chunk] - Data to be written.",
        "@param { string } [encoding] - Encoding type.",
        "@param { Function } [callback] - Callback after writing.",
        "@returns { boolean } Write success returns true, write failure returns false.",
        "@throws { BusinessError } 401 - Parameter error. Possible causes:",
        "@throws { BusinessError } 10200035 - The doWrite method has not been implemented.",
        "@throws { BusinessError } 10200036 - The stream has been ended.",
        "@throws { BusinessError } 10200037 - The callback is invoked multiple times consecutively.",
        "@syscap SystemCapability.Utils.Lang",
        "@crossplatform",
        "@atomicservice",
        "@since 12"
      ],
      "层级": 2,
      "上级": "Writable",
      "since_version": "12",
      "system_capability": "SystemCapability.Utils.Lang",
      "parameters": [
        {
          "名称": "{",
          "类型": "any",
          "必填": true,
          "说明": "Function } [callback] - Callback after writing."
        }
      ],
      "return_description": "Write success returns true, write failure returns false.",
      "error_codes": [
        {
          "code": "401",
          "description": "Parameter error. Possible causes:"
        },
        {
          "code": "10200035",
          "description": "The doWrite method has not been implemented."
        },
        {
          "code": "10200036",
          "description": "The stream has been ended."
        },
        {
          "code": "10200037",
          "description": "The callback is invoked multiple times consecutively."
        }
      ],
      "版本": "API6.0"
