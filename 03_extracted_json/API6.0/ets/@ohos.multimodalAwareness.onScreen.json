    {
      "类型": "method",
      "名称": "getPageContent",
      "返回值": "Promise<PageContent>",
      "所属模块": "未知模块",
      "功能描述": "Get page content <br> permission: ohos.permission.GET_SCREEN_CONTENT. <br> device capabilities. <br> when screen is splited. 2. passed window id is not on screen or floating.",
      "注释信息": [
        "@permission ohos.permission.GET_SCREEN_CONTENT",
        "@param { ContentOptions } [options] - Indicates options to get page content",
        "@returns { Promise<PageContent> } Indicates the promise which carrys retrieved page content",
        "@throws { BusinessError } 201 - Permission denied. An attempt was made to get page content forbidden by",
        "@throws { BusinessError } 202 - Permission check failed. A non-system application uses the system API.",
        "@throws { BusinessError } 801 - Capability not supported. Function can not work correctly due to limited",
        "@throws { BusinessError } 34000001 - Service exception.",
        "@throws { BusinessError } 34000002 - The application or page is not supported.",
        "@throws { BusinessError } 34000003 - The window ID is invalid. Possible causes: 1. window id is not passed",
        "@throws { BusinessError } 34000004 - The page is not ready.",
        "@throws { BusinessError } 34000006 - The request timed out.",
        "@syscap SystemCapability.MultimodalAwareness.OnScreenAwareness",
        "@systemapi",
        "@since 20"
      ],
      "层级": 1,
      "上级": "onScreen",
      "since_version": "20",
      "system_capability": "SystemCapability.MultimodalAwareness.OnScreenAwareness",
      "parameters": [
        {
          "名称": "{",
          "类型": "any",
          "必填": true,
          "说明": "ContentOptions } [options] - Indicates options to get page content"
        }
      ],
      "return_description": "Indicates the promise which carrys retrieved page content",
      "error_codes": [
        {
          "code": "201",
          "description": "Permission denied. An attempt was made to get page content forbidden by"
        },
        {
          "code": "202",
          "description": "Permission check failed. A non-system application uses the system API."
        },
        {
          "code": "801",
          "description": "Capability not supported. Function can not work correctly due to limited"
        },
        {
          "code": "34000001",
          "description": "Service exception."
        },
        {
          "code": "34000002",
          "description": "The application or page is not supported."
        },
        {
