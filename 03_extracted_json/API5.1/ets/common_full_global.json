    {
      "类型": "method",
      "名称": "setInterval",
      "返回值": "number",
      "所属模块": "@kit.ArkUI",
      "功能描述": "Sets the interval for repeatedly calling a function. For devices of \"tv\", \"phone, tablet\", and \"wearable\" types, this parameter can be a function or string. For devices of \"lite wearable\" and \"smartVision\" types, this parameter must be a function.",
      "注释信息": [
        "@param { Function | string } handler - Indicates the function to be called after the timer goes off.",
        "@param { number } delay - Indicates the interval between each two calls, in milliseconds. The function will be called after this delay.",
        "@param { any[] } arguments - Indicates additional arguments to pass to \"handler\" when the timer goes off.",
        "@returns { number } Returns the timer ID.",
        "@syscap SystemCapability.ArkUI.ArkUI.Lite",
        "@since 3"
      ],
      "层级": 1,
      "上级": "@kit.ArkUI",
      "since_version": "3",
      "system_capability": "SystemCapability.ArkUI.ArkUI.Lite",
      "parameters": [
        {
          "名称": "handler",
          "类型": "Function | string",
          "必填": true,
          "说明": "Indicates the function to be called after the timer goes off."
        },
        {
          "名称": "delay",
          "类型": "number",
          "必填": true,
          "说明": "Indicates the interval between each two calls, in milliseconds. The function will be called after this delay."
        },
        {
          "名称": "arguments",
          "类型": "any[]",
          "必填": true,
          "说明": "Indicates additional arguments to pass to \"handler\" when the timer goes off."
        }
      ],
      "return_description": "Returns the timer ID.",
      "error_codes": [],
      "版本": "API5.1"
    },
    {
      "类型": "method",
      "名称": "setTimeout",
      "返回值": "number",
      "所属模块": "@kit.ArkUI",
      "功能描述": "Sets a timer after which a function will be executed. For devices of \"tv\", \"phone, tablet\", and \"wearable\" types, this parameter can be a function or string. For devices of \"lite wearable\" and \"smartVision\" types, this parameter must be a function. If this parameter is left empty, default value \"0\" will be used, which means that the function will be called immediately or as soon as possible.",
      "注释信息": [
        "@param { Function | string } handler - Indicates the function to be called after the timer goes off.",
        "@param { number } [delay] - Indicates the delay (in milliseconds) after which the function will be called.",
        "@param { any[] } arguments - Indicates additional arguments to pass to \"handler\" when the timer goes off.",
        "@returns { number } Returns the timer ID.",
        "@syscap SystemCapability.ArkUI.ArkUI.Lite",
        "@since 3"
      ],
      "层级": 1,
      "上级": "@kit.ArkUI",
