    {
      "类型": "method",
      "名称": "verifyAuthToken",
      "返回值": "Promise<AuthToken>",
      "所属模块": "未知模块",
      "功能描述": "Verify the authentication token. <br>1. Mandatory parameters are left unspecified. <br>2. Incorrect parameter types. <br>3. Parameter verification failed.",
      "注释信息": [
        "@permission ohos.permission.USE_USER_ACCESS_MANAGER",
        "@param { Uint8Array } authToken - AuthToken to be verified.",
        "@param { number } allowableDuration - Allowable time interval from the authToken is issued till now in milliseconds.",
        "@returns { Promise<AuthToken> } Returns parsed authToken.",
        "@throws { BusinessError } 201 - Permission denied.",
        "@throws { BusinessError } 202 - Not system application.",
        "@throws { BusinessError } 401 - Incorrect parameters. Possible causes:",
        "@throws { BusinessError } 12500002 - General operation error.",
        "@throws { BusinessError } 12500015 - AuthToken integrity check failed.",
        "@throws { BusinessError } 12500016 - AuthToken has expired.",
        "@syscap SystemCapability.UserIAM.UserAuth.Core",
        "@systemapi Hide this for inner system use.",
        "@since 18"
      ],
      "层级": 1,
      "上级": "userAccessCtrl",
      "since_version": "18",
      "system_capability": "SystemCapability.UserIAM.UserAuth.Core",
      "parameters": [
        {
          "名称": "authToken",
          "类型": "Uint8Array",
          "必填": true,
          "说明": "AuthToken to be verified."
        },
        {
          "名称": "allowableDuration",
          "类型": "number",
          "必填": true,
          "说明": "Allowable time interval from the authToken is issued till now in milliseconds."
        }
      ],
      "return_description": "Returns parsed authToken.",
      "error_codes": [
        {
          "code": "201",
          "description": "Permission denied."
        },
        {
          "code": "202",
          "description": "Not system application."
        },
        {
          "code": "401",
          "description": "Incorrect parameters. Possible causes:"
        },
        {
          "code": "12500002",
          "description": "General operation error."
        },
        {
          "code": "12500015",
          "description": "AuthToken integrity check failed."
        },
        {
          "code": "12500016",
          "description": "AuthToken has expired."
        }
      ],
      "版本": "API5.1"
    },
