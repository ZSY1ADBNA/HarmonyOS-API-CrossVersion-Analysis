    {
      "类型": "method",
      "名称": "on",
      "返回值": "void",
      "所属模块": "未知模块",
      "功能描述": "Listens for audio interrupt events. This method uses a callback to get interrupt events. The interrupt event is triggered when audio playback is interrupted. 1.Mandatory parameters are left unspecified; 2.Incorrect parameter types.",
      "注释信息": [
        "@param { 'audioInterrupt' } type - Type of the event to listen for. Only the audioInterrupt event is supported.",
        "@param { Callback<audio.InterruptEvent> } callback - Callback used to listen for interrupt callback.",
        "@throws { BusinessError } 401 - Parameter error. Possible causes:",
        "@throws { BusinessError } 6800101 - Parameter verification failed.",
        "@syscap SystemCapability.Multimedia.SystemSound.Core",
        "@systemapi",
        "@since 10"
      ],
      "层级": 1,
      "上级": "RingtonePlayer",
      "since_version": "10",
      "system_capability": "SystemCapability.Multimedia.SystemSound.Core",
      "parameters": [
        {
          "名称": "type",
          "类型": "'audioInterrupt'",
          "必填": true,
          "说明": "Type of the event to listen for. Only the audioInterrupt event is supported."
        },
        {
          "名称": "callback",
          "类型": "Callback<audio.InterruptEvent>",
          "必填": true,
          "说明": "Callback used to listen for interrupt callback."
        }
      ],
      "return_description": "",
      "error_codes": [
        {
          "code": "401",
          "description": "Parameter error. Possible causes:"
        },
        {
          "code": "6800101",
          "description": "Parameter verification failed."
        }
