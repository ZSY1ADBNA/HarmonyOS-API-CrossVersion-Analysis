    {
      "类型": "method",
      "名称": "enableAbility",
      "返回值": "Promise<void>",
      "所属模块": "未知模块",
      "功能描述": "Enable the accessibility extension ability. The application does not have the permission required to call the API. 1. Mandatory parameters are left unspecified; 2. Incorrect parameter types; 3. Parameter verification failed.",
      "注释信息": [
        "@permission ohos.permission.WRITE_ACCESSIBILITY_CONFIG",
        "@param { string } name Indicates the accessibility extension name, in \"bundleName/abilityName\" format.",
        "@param { Array<accessibility.Capability> } capability Indicates the ability.",
        "@returns { Promise<void> }",
        "@throws { BusinessError } 201 - Permission verification failed.",
        "@throws { BusinessError } 202 - Permission verification failed. A non-system application calls a system API.",
        "@throws { BusinessError } 401 - Input parameter error. Possible causes:",
        "@throws { BusinessError } 9300001 - Invalid bundle name or ability name.",
        "@throws { BusinessError } 9300002 - Target ability already enabled.",
        "@syscap SystemCapability.BarrierFree.Accessibility.Core",
        "@systemapi",
        "@since 9"
      ],
      "层级": 1,
      "上级": "config",
      "since_version": "9",
      "system_capability": "SystemCapability.BarrierFree.Accessibility.Core",
      "parameters": [
        {
          "名称": "name",
          "类型": "string",
          "必填": true,
          "说明": "Indicates the accessibility extension name, in \"bundleName/abilityName\" format."
        },
        {
          "名称": "capability",
          "类型": "Array<accessibility.Capability>",
          "必填": true,
          "说明": "Indicates the ability."
        }
      ],
      "return_description": "",
      "error_codes": [
        {
          "code": "201",
          "description": "Permission verification failed."
        },
        {
          "code": "202",
          "description": "Permission verification failed. A non-system application calls a system API."
        },
        {
          "code": "401",
          "description": "Input parameter error. Possible causes:"
        },
        {
          "code": "9300001",
          "description": "Invalid bundle name or ability name."
        },
        {
          "code": "9300002",
          "description": "Target ability already enabled."
        }
      ],
      "版本": "API5.1"
    },
