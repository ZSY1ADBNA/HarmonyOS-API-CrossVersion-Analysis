      "类型": "method",
      "名称": "getLauncherAbilityInfoSync",
      "返回值": "Array<LauncherAbilityInfo>",
      "所属模块": "未知模块",
      "功能描述": "Obtains launcher abilities info based on a given bundleName and userId.",
      "注释信息": [
        "@permission ohos.permission.GET_BUNDLE_INFO_PRIVILEGED",
        "@param { string } bundleName - Indicates the application bundle name to be queried.",
        "@param { number } userId - Indicates the id for the user.",
        "@returns { Array<LauncherAbilityInfo> } the LauncherAbilityInfo object.",
        "@throws { BusinessError } 201 - Verify permission denied.",
        "@throws { BusinessError } 801 - Capability not support.",
        "@throws { BusinessError } 17700001 - The specified bundle name is not found.",
        "@throws { BusinessError } 17700004 - The specified user ID is not found.",
        "@syscap SystemCapability.BundleManager.BundleFramework.Launcher",
        "@since 18"
      ],
      "层级": 1,
      "上级": "launcherBundleManager",
      "since_version": "18",
      "system_capability": "SystemCapability.BundleManager.BundleFramework.Launcher",
      "parameters": [
        {
          "名称": "bundleName",
          "类型": "string",
          "必填": true,
          "说明": "Indicates the application bundle name to be queried."
        },
        {
          "名称": "userId",
          "类型": "number",
          "必填": true,
          "说明": "Indicates the id for the user."
        }
      ],
      "return_description": "the LauncherAbilityInfo object.",
      "error_codes": [
        {
          "code": "201",
          "description": "Verify permission denied."
        },
        {
          "code": "801",
          "description": "Capability not support."
        },
        {
          "code": "17700001",
          "description": "The specified bundle name is not found."
        },
        {
