      "parameters": [
        {
          "名称": "ad",
          "类型": "Advertisement",
          "必填": true,
          "说明": "Indicates the advertisement content information. ad is required."
        },
        {
          "名称": "options",
          "类型": "AdDisplayOptions",
          "必填": true,
          "说明": "Indicates interaction option object use to show the ad. options is required."
        },
        {
          "名称": "{",
