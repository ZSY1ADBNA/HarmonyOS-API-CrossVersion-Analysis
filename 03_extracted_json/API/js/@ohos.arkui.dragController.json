        "@throws { BusinessError } 100001 - Internal handling failed.",
        "@syscap SystemCapability.ArkUI.ArkUI.Full",
        "@crossplatform",
        "@atomicservice",
        "@since 18",
        "@deprecated since 18",
        "@useinstead ohos.arkui.UIContext.DragController#executeDrag"
