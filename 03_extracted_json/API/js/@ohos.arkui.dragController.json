      "上级": "dragController",
      "since_version": "18",
      "system_capability": "SystemCapability.ArkUI.ArkUI.Full",
      "parameters": [
        {
          "名称": "custom",
          "类型": "CustomBuilder | DragItemInfo",
          "必填": true,
          "说明": "Object used for prompts displayed when the object is dragged."
        },
        {
          "名称": "dragInfo",
          "类型": "DragInfo",
          "必填": true,
          "说明": "Information about the drag event."
        },
        {
          "名称": "callback",
          "类型": "AsyncCallback<DragEventParam>",
