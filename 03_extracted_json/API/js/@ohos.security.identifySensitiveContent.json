    {
      "类型": "method",
      "名称": "scanFile",
      "返回值": "Promise<Array<MatchResult>>",
      "所属模块": "未知模块",
      "功能描述": "Identify sensitive content from file based on policy. 1. Incorrect policy format. 2. Invalid parameter range. 1. The file path does not exist. 2. The file type is not supported. 3. The file permission is not supported.",
      "注释信息": [
        "@permission ohos.permission.ENTERPRISE_DATA_IDENTIFY_FILE",
        "@param { string } filePath - To be idetified file path",
        "@param { Array<Policy> } identifyPolicies - Identify Policy",
        "@returns { Promise<Array<MatchResult>> } Identify result of Sensitive content",
        "@throws { BusinessError } 201 - permission denied.",
        "@throws { BusinessError } 801 - Capability not supported.",
        "@throws { BusinessError } 19110001 - Parameter error. Possible causes:",
        "@throws { BusinessError } 19110002 - Sensitive file content identification timed out.",
        "@throws { BusinessError } 19110003 - The file is not supported. Possible causes:",
        "@throws { BusinessError } 19110004 - A system error has occurred.",
        "@syscap SystemCapability.Security.DataLossPrevention",
        "@since 21"
      ],
      "层级": 1,
      "上级": "identifySensitiveContent",
      "since_version": "21",
      "system_capability": "SystemCapability.Security.DataLossPrevention",
      "parameters": [
        {
          "名称": "filePath",
          "类型": "string",
          "必填": true,
          "说明": "To be idetified file path"
        },
        {
          "名称": "identifyPolicies",
          "类型": "Array<Policy>",
          "必填": true,
          "说明": "Identify Policy"
        }
      ],
      "return_description": "Identify result of Sensitive content",
