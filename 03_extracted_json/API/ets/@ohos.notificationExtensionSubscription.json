    {
      "类型": "method",
      "名称": "openSubscriptionSettings",
      "返回值": "Promise<void>",
      "所属模块": "未知模块",
      "功能描述": "Opens the notification extension subscription settings page of the application, which is displayed in semi-modal mode and can be used to set the notification enabling and notification mode. This API uses a promise to return the result.",
      "注释信息": [
        "@permission ohos.permission.SUBSCRIBE_NOTIFICATION",
        "@param { UIAbilityContext } context - Ability context bound to the notification settings page.",
        "@returns { Promise<void> } The promise returned by the function.",
        "@throws { BusinessError } 201 - Permission denied or current device not supported.",
        "@throws { BusinessError } 1600001 - Internal error.",
        "@throws { BusinessError } 1600018 - The notification settings window is already displayed.",
        "@throws { BusinessError } 1600023 - The application does not implement the NotificationSubscriberExtensionAbility.",
        "@syscap SystemCapability.Notification.Notification",
        "@since 22"
      ],
      "层级": 1,
      "上级": "notificationExtensionSubscription",
      "since_version": "22",
      "system_capability": "SystemCapability.Notification.Notification",
      "parameters": [
        {
          "名称": "context",
          "类型": "UIAbilityContext",
          "必填": true,
          "说明": "Ability context bound to the notification settings page."
        }
      ],
      "return_description": "The promise returned by the function.",
      "error_codes": [
        {
          "code": "201",
          "description": "Permission denied or current device not supported."
        },
        {
          "code": "1600001",
          "description": "Internal error."
        },
        {
          "code": "1600018",
          "description": "The notification settings window is already displayed."
        },
        {
          "code": "1600023",
          "description": "The application does not implement the NotificationSubscriberExtensionAbility."
        }
      ],
      "版本": "API"
    },
