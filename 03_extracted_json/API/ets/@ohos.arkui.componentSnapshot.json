      "类型": "property",
      "名称": "colorSpace",
      "属性类型": "colorSpaceManager.ColorSpace",
      "所属模块": "未知模块",
      "功能描述": "Set one specific color space which want to be used.",
      "注释信息": [
        "@type { ?colorSpaceManager.ColorSpace }",
