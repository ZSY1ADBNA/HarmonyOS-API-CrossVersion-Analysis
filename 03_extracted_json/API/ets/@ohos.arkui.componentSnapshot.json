    },
    {
      "类型": "property",
      "名称": "isAuto",
      "属性类型": "boolean",
      "所属模块": "未知模块",
      "功能描述": "Indicate that if the system should decide the color space automaticlly. If set this to true, the one specificed by colorSpace parameter will be ignored. When setting isAuto to true, it is recommended to also set the waitUntilRenderFinished field in SnapshotOptions to true to ensure that the system can properly detect the mode being used. True means ignoring the value set via the colorSpace field and letting the system decide based on the actual component situation. False means using the value set via the colorSpace field. The default value is false.",
      "注释信息": [
        "@type { ?boolean } - Whether to let the system automatically determine the color space used for screenshots.",
        "@syscap SystemCapability.ArkUI.ArkUI.Full",
        "@atomicservice",
        "@since 23"
      ],
      "层级": 2,
      "上级": "ColorModeOptions",
