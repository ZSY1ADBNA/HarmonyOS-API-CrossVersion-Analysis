    {
      "类型": "method",
      "名称": "getPlayingState",
      "返回值": "PlayingState",
      "所属模块": "未知模块",
      "功能描述": "Obtains the playing state of device. <br>2. Incorrect parameter types. 3. Parameter verification failed.",
      "注释信息": [
        "@permission ohos.permission.ACCESS_BLUETOOTH",
        "@param { string } deviceId - Indicates device ID. For example, \"11:22:33:AA:BB:FF\".",
        "@returns { PlayingState } Returns the playing state.",
        "@throws { BusinessError } 201 - Permission denied.",
        "@throws { BusinessError } 401 - Invalid parameter. Possible causes: 1. Mandatory parameters are left unspecified.",
        "@throws { BusinessError } 801 - Capability not supported.",
        "@throws { BusinessError } 2900001 - Service stopped.",
        "@throws { BusinessError } 2900003 - Bluetooth disabled.",
        "@throws { BusinessError } 2900004 - Profile not supported.",
        "@throws { BusinessError } 2900099 - Operation failed.",
        "@syscap SystemCapability.Communication.Bluetooth.Core",
        "@since 10"
      ],
      "层级": 2,
      "上级": "A2dpSourceProfile",
      "since_version": "10",
      "system_capability": "SystemCapability.Communication.Bluetooth.Core",
      "parameters": [
        {
          "名称": "deviceId",
          "类型": "string",
          "必填": true,
          "说明": "Indicates device ID. For example, \"11:22:33:AA:BB:FF\"."
        }
      ],
      "return_description": "Returns the playing state.",
      "error_codes": [
        {
          "code": "201",
          "description": "Permission denied."
        },
        {
          "code": "401",
          "description": "Invalid parameter. Possible causes: 1. Mandatory parameters are left unspecified."
        },
        {
          "code": "801",
          "description": "Capability not supported."
        },
        {
          "code": "2900001",
          "description": "Service stopped."
        },
        {
          "code": "2900003",
          "description": "Bluetooth disabled."
        },
        {
          "code": "2900004",
          "description": "Profile not supported."
        },
        {
          "code": "2900099",
          "description": "Operation failed."
        }
      ],
